13:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"6. Retention of Your Personal Data"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","p",null,{"children":"The Company will retain your Personal Data only for as long as is necessary for the purposes set out in this Privacy Policy. We will retain and use your Personal Data to the extent necessary to comply with our legal obligations (for example, if we are required to retain your data to comply with applicable laws), resolve disputes, and enforce our legal agreements and policies."}],["$","p",null,{"className":"mt-2","children":"The Company will also retain Usage Data for internal analysis purposes. Usage Data is generally retained for a shorter period of time, except when this data is used to strengthen the security or to improve the functionality of our Service, or we are legally obligated to retain this data for longer time periods."}]]}]]}]
14:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"7. Transfer of Your Personal Data"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","p",null,{"children":"Your information, including Personal Data, is processed at the Company's operating offices and in any other places where the parties involved in the processing are located. It means that this information may be transferred to — and maintained on — computers located outside of your state, province, country, or other governmental jurisdiction where the data protection laws may differ than those from your jurisdiction."}],["$","p",null,{"className":"mt-2","children":"Your consent to this Privacy Policy followed by your submission of such information represents your agreement to that transfer."}],["$","p",null,{"className":"mt-2","children":"The Company will take all steps reasonably necessary to ensure that your data is treated securely and in accordance with this Privacy Policy and no transfer of your Personal Data will take place to an organization or a country unless there are adequate controls in place including the security of your data and other personal information."}]]}]]}]
15:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"8. Disclosure of Your Personal Data"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","h3",null,{"className":"text-white/60 font-medium text-sm mt-3 mb-2","children":"8.1 Business Transactions"}],["$","p",null,{"children":"If the Company is involved in a merger, acquisition, or asset sale, your Personal Data may be transferred. We will provide notice before your Personal Data is transferred and becomes subject to a different Privacy Policy."}],["$","h3",null,{"className":"text-white/60 font-medium text-sm mt-3 mb-2","children":"8.2 Law Enforcement"}],["$","p",null,{"children":"Under certain circumstances, the Company may be required to disclose your Personal Data if required to do so by law or in response to valid requests by public authorities (e.g., a court or a government agency)."}],["$","h3",null,{"className":"text-white/60 font-medium text-sm mt-3 mb-2","children":"8.3 Other Legal Requirements"}],["$","p",null,{"children":"The Company may disclose your Personal Data in the good faith belief that such action is necessary to:"}],["$","ul",null,{"className":"list-disc list-inside text-white/40 text-sm space-y-1.5 pl-1 mt-2","children":[["$","li",null,{"children":"Comply with a legal obligation"}],["$","li",null,{"children":"Protect and defend the rights or property of the Company"}],["$","li",null,{"children":"Prevent or investigate possible wrongdoing in connection with the Service"}],["$","li",null,{"children":"Protect the personal safety of Users of the Service or the public"}],["$","li",null,{"children":"Protect against legal liability"}]]}]]}]]}]
16:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"9. Delete Your Personal Data"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","p",null,{"children":"You have the right to delete or request that we assist in deleting the Personal Data that we have collected about you."}],["$","p",null,{"className":"mt-2","children":"You may contact us to request access to, correct, or delete any personal information that you have provided to us, including requesting the deletion of your account. To submit a data deletion request, please email our support team at support@aicrix.com."}],["$","p",null,{"className":"mt-2","children":"Please note, however, that we may need to retain certain information when we have a legal obligation or lawful basis to do so."}]]}]]}]
17:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"10. Security of Your Personal Data"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","p",null,{"children":"The security of your Personal Data is important to us, but remember that no method of transmission over the Internet, or method of electronic storage is 100% secure. While we strive to use commercially acceptable means to protect your Personal Data, we cannot guarantee its absolute security."}],["$","p",null,{"className":"mt-2","children":"We employ industry-standard security measures including:"}],["$","ul",null,{"className":"list-disc list-inside text-white/40 text-sm space-y-1.5 pl-1 mt-2","children":[["$","li",null,{"children":"Encrypted data transmission (SSL/TLS)"}],["$","li",null,{"children":"Secure data storage with access controls"}],["$","li",null,{"children":"Regular security audits and vulnerability assessments"}],["$","li",null,{"children":"Employee training on data protection best practices"}],["$","li",null,{"children":"Incident response procedures for data breaches"}]]}]]}]]}]
18:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"11. Children's Privacy"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","p",null,{"children":"Our Service does not address anyone under the age of 13. We do not knowingly collect personally identifiable information from anyone under the age of 13. If you are a parent or guardian and you are aware that your child has provided us with Personal Data, please contact us. If we become aware that we have collected Personal Data from anyone under the age of 13 without verification of parental consent, we take steps to remove that information from our servers."}],["$","p",null,{"className":"mt-2","children":"If we need to rely on consent as a legal basis for processing your information and your country requires consent from a parent, we may require your parent's consent before we collect and use that information."}]]}]]}]
19:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"12. Links to Other Websites"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","p",null,{"children":"Our Service may contain links to other websites that are not operated by us. If you click on a third-party link, you will be directed to that third party's site. We strongly advise you to review the Privacy Policy of every site you visit."}],["$","p",null,{"className":"mt-2","children":"We have no control over and assume no responsibility for the content, privacy policies, or practices of any third-party sites or services."}]]}]]}]
1a:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"13. Changes to This Privacy Policy"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","p",null,{"children":"We may update our Privacy Policy from time to time. We will notify you of any changes by posting the new Privacy Policy on this page and updating the \"Last Updated\" date at the top of this Privacy Policy."}],["$","p",null,{"className":"mt-2","children":"You are advised to review this Privacy Policy periodically for any changes. Changes to this Privacy Policy are effective when they are posted on this page."}],["$","p",null,{"className":"mt-2","children":"Where required by applicable law, we will notify you via email and/or a prominent notice on our Service prior to the change becoming effective."}]]}]]}]
1b:["$","div",null,{"children":[["$","h2",null,{"className":"page-section-title","children":"14. Your Data Protection Rights"}],["$","div",null,{"className":"page-section-body space-y-3","children":[["$","p",null,{"children":"Depending on your location and applicable data protection laws, you may have the following rights regarding your Personal Data:"}],["$","ul",null,{"className":"list-disc list-inside text-white/40 text-sm space-y-1.5 pl-1 mt-2","children":[["$","li",null,{"children":[["$","strong",null,{"className":"text-white/50","children":"Right to Access:"}]," You have the right to request copies of your Personal Data."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white/50","children":"Right to Rectification:"}]," You have the right to request that we correct any information you believe is inaccurate or complete information you believe is incomplete."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white/50","children":"Right to Erasure:"}]," You have the right to request that we erase your Personal Data, under certain conditions."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white/50","children":"Right to Restrict Processing:"}]," You have the right to request that we restrict the processing of your Personal Data, under certain conditions."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white/50","children":"Right to Object to Processing:"}]," You have the right to object to our processing of your Personal Data, under certain conditions."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white/50","children":"Right to Data Portability:"}]," You have the right to request that we transfer the data collected to another organization, or directly to you, under certain conditions."]}]]}],["$","p",null,{"className":"mt-2","children":"If you make a request, we have one month to respond to you. To exercise any of these rights, please contact us at our contact details below."}]]}]]}]
